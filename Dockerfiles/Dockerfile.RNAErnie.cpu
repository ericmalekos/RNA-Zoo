FROM condaforge/miniforge3:latest

LABEL org.opencontainers.image.source="https://github.com/CatIIIIIIII/RNAErnie"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.title="rnaernie-cpu"
LABEL org.opencontainers.image.description="ERNIE-framework RNA language model — CPU-only build via the LLM-EDA/RNAErnie HF port (Apache-2.0)."

RUN apt-get update && apt-get install -y --no-install-recommends wget && \
    rm -rf /var/lib/apt/lists/*

RUN mamba create -n rnaernie -c pytorch -c conda-forge -y \
        python=3.10 \
        pytorch=2.2 \
        cpuonly \
        "numpy<2" \
        pip \
    && mamba clean -afy

ENV PATH="/opt/conda/envs/rnaernie/bin:$PATH"
ENV CONDA_DEFAULT_ENV=rnaernie

RUN /opt/conda/envs/rnaernie/bin/pip install --no-cache-dir \
        "transformers<4.50" \
        "huggingface_hub<0.25"

RUN /opt/conda/envs/rnaernie/bin/python -c "\
from huggingface_hub import snapshot_download; \
snapshot_download(repo_id='LLM-EDA/RNAErnie', \
                  local_dir='/opt/rnaernie_weights', \
                  local_dir_use_symlinks=False)"

COPY bin/rnaernie_predict.py /opt/bin/rnaernie_predict.py
RUN chmod +x /opt/bin/rnaernie_predict.py
ENV PATH="/opt/bin:$PATH"

ENV HF_HOME=/tmp/hf_cache
ENV HF_HUB_OFFLINE=1

WORKDIR /opt
