/*
========================================================================================
    RNAZoo Nextflow config
========================================================================================
    Models are opt-in: only models with a non-null _input parameter will run.
    Provide inputs via CLI flags, or use --params_yaml to load from a YAML file.
    See conf/params_template.yml for all available parameters.
========================================================================================
*/

manifest {
    name            = 'RNAZoo'
    author          = 'Eric'
    homePage        = 'https://github.com/ericmalekos/RNA-Zoo'
    description     = 'Model zoo for RNA deep learning'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.2.0'
}

// Default pipeline parameters — all inputs null (opt-in).
params {

    // Global output root. Per-model outputs default to <outdir>/<model_name>/.
    outdir = 'results'

    // ===================== Translation =====================

    ribonn_input                  = null
    ribonn_outdir                 = null     // default: <outdir>/ribonn
    ribonn_species                = 'human'
    ribonn_checkpoint             = null     // optional: path to fine-tuned .ckpt checkpoint

    // RiboNN fine-tuning (transfer learning on user TE data)
    ribonn_finetune_input         = null     // tab-separated: tx_id, utr5, cds, utr3, <target>
    ribonn_finetune_outdir        = null     // default: <outdir>/ribonn_finetune
    ribonn_finetune_target        = null     // required: column name with TE values
    ribonn_finetune_phase1_epochs = 50
    ribonn_finetune_phase2_epochs = 150
    ribonn_finetune_patience      = 50
    ribonn_finetune_folds         = 5

    riboformer_input              = null
    riboformer_outdir             = null     // default: <outdir>/riboformer
    riboformer_reference_wig      = null
    riboformer_target_wig         = null
    riboformer_model              = 'yeast_disome'
    riboformer_psite              = 14
    riboformer_wsize              = 40
    riboformer_threshold          = 25
    riboformer_plot               = false    // generate ribosome density plot
    // Use a bundled in-image dataset instead of staging external WIG/FASTA/GFF.
    // Set to a name from /opt/Riboformer/datasets/ (e.g. "GSE119104_Mg_buffer").
    // When set, --riboformer_input is ignored.
    riboformer_bundled_dataset    = null

    ribotie_input                 = null
    ribotie_outdir                = null     // default: <outdir>/ribotie
    ribotie_config                = null
    ribotie_max_epochs            = null
    ribotie_patience              = null
    // Optional path to a fine-tuned .rt.ckpt from a previous ribotie run.
    // When set, each fold's transfer_checkpoint line in the YAML is rewritten
    // to point at this file so the model skips re-fine-tuning.
    ribotie_checkpoint            = null

    seq2ribo_input                = null     // GPU-only; auto-skipped on CPU
    seq2ribo_outdir               = null     // default: <outdir>/seq2ribo
    seq2ribo_task                 = 'te'
    seq2ribo_cell_line            = 'hek293'
    seq2ribo_use_utr              = false

    translationai_input           = null
    translationai_outdir          = null     // default: <outdir>/translationai
    translationai_tis_threshold   = 0.5
    translationai_tts_threshold   = 0.5

    saluki_input                  = null
    saluki_outdir                 = null     // default: <outdir>/saluki
    saluki_species                = 'human'

    codontransformer_input        = null
    codontransformer_outdir       = null     // default: <outdir>/codontransformer
    codontransformer_organism     = 'Homo sapiens'

    // ===================== RNA Foundation Models =====================

    rnafm_input                   = null
    rnafm_outdir                  = null     // default: <outdir>/rnafm
    rnafm_per_token               = false
    rnafm_max_len                 = 1022     // truncate inputs to this many nt (model context cap)
    rnafm_batch_size              = 8

    // RNA-FM linear-probe fine-tuning (frozen backbone + MLP head on user labels)
    rnafm_finetune_input          = null     // TSV/CSV: name, sequence, <label_column>
    rnafm_finetune_outdir         = null     // default: <outdir>/rnafm_finetune
    rnafm_finetune_label          = null     // required: column name with target values
    rnafm_finetune_epochs         = 20
    rnafm_finetune_lr             = 1e-3
    rnafm_finetune_embeddings     = null     // optional: precomputed (N, D) .npy; skips predict step
    rnafm_finetune_head_type      = 'linear' // linear | mlp | xgboost (xgboost requires _embeddings)
    rnafm_finetune_task           = 'auto'   // auto | regression | classification

    rinalmo_input                 = null
    rinalmo_outdir                = null     // default: <outdir>/rinalmo
    rinalmo_per_token             = false
    rinalmo_batch_size            = 1        // 650M backbone — keep small to avoid OOM

    // RiNALMo linear-probe fine-tuning
    rinalmo_finetune_input        = null
    rinalmo_finetune_outdir       = null
    rinalmo_finetune_label        = null
    rinalmo_finetune_epochs       = 20
    rinalmo_finetune_lr           = 1e-3
    rinalmo_finetune_embeddings   = null     // optional: precomputed (N, D) .npy; skips predict step
    rinalmo_finetune_head_type    = 'linear'
    rinalmo_finetune_task         = 'auto'

    ernierna_input                = null
    ernierna_outdir               = null     // default: <outdir>/ernierna
    ernierna_per_token            = false
    ernierna_max_len              = 1022     // truncate inputs to this many nt (model context cap)

    // ERNIE-RNA linear-probe fine-tuning
    ernierna_finetune_input       = null
    ernierna_finetune_outdir      = null
    ernierna_finetune_label       = null
    ernierna_finetune_epochs      = 20
    ernierna_finetune_lr          = 1e-3
    ernierna_finetune_embeddings  = null     // optional: precomputed (N, D) .npy; skips predict step
    ernierna_finetune_head_type   = 'linear'
    ernierna_finetune_task        = 'auto'

    orthrus_input                 = null     // GPU-only; auto-skipped on CPU
    orthrus_outdir                = null     // default: <outdir>/orthrus
    orthrus_variant               = 'v1_4_track'
    orthrus_per_token             = false
    orthrus_min_len               = 200      // warn (don't refuse) when sequences are shorter than this

    // Orthrus linear-probe fine-tuning (GPU-only; auto-skipped on CPU)
    orthrus_finetune_input        = null
    orthrus_finetune_outdir       = null
    orthrus_finetune_label        = null
    orthrus_finetune_epochs       = 20
    orthrus_finetune_lr           = 1e-3
    orthrus_finetune_embeddings   = null     // optional: precomputed (N, D) .npy; skips predict step
    orthrus_finetune_head_type    = 'linear'
    orthrus_finetune_task         = 'auto'

    rnaernie_input                = null
    rnaernie_outdir               = null     // default: <outdir>/rnaernie
    rnaernie_per_token            = false
    rnaernie_max_len              = 2046     // truncate inputs to this many nt (model context cap)
    rnaernie_batch_size           = 8

    // RNAErnie linear-probe fine-tuning
    rnaernie_finetune_input       = null
    rnaernie_finetune_outdir      = null
    rnaernie_finetune_label       = null
    rnaernie_finetune_epochs      = 20
    rnaernie_finetune_lr          = 1e-3
    rnaernie_finetune_embeddings  = null     // optional: precomputed (N, D) .npy; skips predict step
    rnaernie_finetune_head_type   = 'linear'
    rnaernie_finetune_task        = 'auto'

    plantrnafm_input              = null
    plantrnafm_outdir             = null     // default: <outdir>/plantrnafm
    plantrnafm_per_token          = false
    plantrnafm_max_len            = 1024     // truncate inputs to this many nt (model context cap)
    plantrnafm_batch_size         = 8

    // PlantRNA-FM linear-probe fine-tuning
    plantrnafm_finetune_input     = null
    plantrnafm_finetune_outdir    = null
    plantrnafm_finetune_label     = null
    plantrnafm_finetune_epochs    = 20
    plantrnafm_finetune_lr        = 1e-3
    plantrnafm_finetune_embeddings = null    // optional: precomputed (N, D) .npy; skips predict step
    plantrnafm_finetune_head_type = 'linear'
    plantrnafm_finetune_task      = 'auto'

    calm_input                    = null
    calm_outdir                   = null     // default: <outdir>/calm
    calm_per_token                = false
    calm_max_codons               = 1024     // truncate to this many codons (CaLM's max_positions)

    // CaLM linear-probe fine-tuning
    calm_finetune_input           = null
    calm_finetune_outdir          = null
    calm_finetune_label           = null
    calm_finetune_epochs          = 20
    calm_finetune_lr              = 1e-3
    calm_finetune_embeddings      = null     // optional: precomputed (N, D) .npy; skips predict step
    calm_finetune_head_type       = 'linear'
    calm_finetune_task            = 'auto'

    mrnabert_input                = null
    mrnabert_outdir               = null     // default: <outdir>/mrnabert
    mrnabert_per_token            = false
    mrnabert_max_tokens           = 1024     // truncate to this many tokens (tokenizer model_max_length)

    // mRNABERT linear-probe fine-tuning
    mrnabert_finetune_input       = null
    mrnabert_finetune_outdir      = null
    mrnabert_finetune_label       = null
    mrnabert_finetune_epochs      = 20
    mrnabert_finetune_lr          = 1e-3
    mrnabert_finetune_embeddings  = null     // optional: precomputed (N, D) .npy; skips predict step
    mrnabert_finetune_head_type   = 'linear'
    mrnabert_finetune_task        = 'auto'

    hydrarna_input                = null     // GPU-only; auto-skipped on CPU
    hydrarna_outdir               = null     // default: <outdir>/hydrarna
    hydrarna_per_token            = false
    hydrarna_no_half              = false    // when true, disable model.half() (use full fp32 instead of fp16)

    // HydraRNA linear-probe fine-tuning (GPU-only; auto-skipped on CPU)
    hydrarna_finetune_input       = null
    hydrarna_finetune_outdir      = null
    hydrarna_finetune_label       = null
    hydrarna_finetune_epochs      = 20
    hydrarna_finetune_lr          = 1e-3
    hydrarna_finetune_embeddings  = null     // optional: precomputed (N, D) .npy; skips predict step
    hydrarna_finetune_head_type   = 'linear'
    hydrarna_finetune_task        = 'auto'

    // ===================== RNA Structure =====================

    rnaformer_input               = null
    rnaformer_outdir              = null     // default: <outdir>/rnaformer
    rnaformer_cycling             = 6
    rnaformer_save_matrix         = false
    rnaformer_plot                = false    // generate contact map heatmaps

    rhofold_input                 = null
    rhofold_outdir                = null     // default: <outdir>/rhofold

    spotrna_input                 = null
    spotrna_outdir                = null     // default: <outdir>/spotrna
    spotrna_plot                  = false    // generate contact map heatmaps

    drfold2_input                 = null     // GPU-only; auto-skipped on CPU
    drfold2_outdir                = null     // default: <outdir>/drfold2
    drfold2_cluster               = false    // also run clustering pass for alternative models
    drfold2_keep_intermediate     = false    // retain per-sequence working dirs

    // ===================== RNA Modification =====================

    multirm_input                 = null
    multirm_outdir                = null     // default: <outdir>/multirm
    multirm_alpha                 = 0.05
    multirm_plot                  = false    // generate modification heatmaps

    // ===================== mRNA Design =====================

    utrlm_input                   = null
    utrlm_outdir                  = null     // default: <outdir>/utrlm
    utrlm_task                    = 'mrl'
    utrlm_cell_line               = 'HEK'
    utrlm_checkpoint              = null     // optional: path to fine-tuned .pt checkpoint

    // UTR-LM fine-tuning on user expression data
    utrlm_finetune_input          = null     // CSV/TSV: name, utr, <label_column>
    utrlm_finetune_outdir         = null     // default: <outdir>/utrlm_finetune
    utrlm_finetune_label          = null     // required: column name with target values
    utrlm_finetune_task           = 'mrl'    // mrl, te, or el (determines backbone)
    utrlm_finetune_epochs         = 100
    utrlm_finetune_patience       = 20
    utrlm_finetune_lr             = 0.01
    utrlm_finetune_pretrained     = null     // optional: path to pretrained checkpoint
}

// Default container engine options
docker.enabled    = false
singularity.enabled = false

profiles {
    docker {
        docker.enabled         = true
        // HOME=/tmp + USER=nextflow let torch._dynamo's import-time cache_dir()
        // work when the host UID isn't in the container's /etc/passwd
        // (GHA runners run as UID 1001; local dev usually UID 1000 which tends
        //  to exist in Ubuntu-based base images).
        docker.runOptions      = '-u $(id -u):$(id -g) -e HOME=/tmp -e USER=nextflow'
        singularity.enabled    = false
    }

    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        // OCI→SIF conversion of the larger rnazoo images (rinalmo-cpu 3 GB,
        // ernierna 5.7 GB, seq2ribo 10.3 GB compressed) can blow past the
        // default 20m pull timeout on slow CI runners.
        singularity.pullTimeout = '60m'
        // Redirect framework caches to /tmp so read-only rootfs runtimes
        // (Singularity CE 3.8 underlay mode) don't block HuggingFace /
        // matplotlib / XDG writes. HOME is included for completeness; some
        // Singularity versions silently ignore it with "Overriding HOME is
        // not permitted", but HF_HOME/XDG_CACHE_HOME are honored and cover
        // the cases that matter.
        singularity.runOptions  = '--env HOME=/tmp --env HF_HOME=/tmp --env MPLCONFIGDIR=/tmp --env TRANSFORMERS_CACHE=/tmp --env XDG_CACHE_HOME=/tmp'
        docker.enabled          = false
    }

    cpu {
        params.device = 'cpu'
    }

    gpu {
        params.device = 'gpu'
        docker.runOptions = '--runtime=nvidia -e NVIDIA_VISIBLE_DEVICES=all -u $(id -u):$(id -g) -e HOME=/tmp -e USER=nextflow'
    }

    test {
        includeConfig 'conf/test.config'
    }

    test_gpu {
        includeConfig 'conf/test.config'
        includeConfig 'conf/test_gpu.config'
    }

    test_finetune {
        // Opt-in profile that exercises the linear-probe fine-tune for every
        // foundation model. Layers on top of `test` (so inference + fine-tune
        // both run). GPU-only fine-tunes (Orthrus, HydraRNA) auto-skip under cpu.
        includeConfig 'conf/test.config'
        includeConfig 'conf/test_finetune.config'
    }

    test_finetune_from_emb {
        // Opt-in profile that exercises the precomputed-embeddings short-circuit
        // for every foundation model. Skips the predict step and feeds a
        // generic (30, 256) random .npy directly into the head trainer.
        // Smoke verifies wiring; learning quality on random embeddings is
        // meaningless and val Pearson r will be near zero.
        includeConfig 'conf/test_finetune_from_emb.config'
    }

    test_finetune_classify {
        // Opt-in profile that exercises classification + linear head on every
        // foundation model via the embeddings shortcut. Uses the random
        // embeddings fixture and a 2-class string label fixture.
        includeConfig 'conf/test_finetune_classify.config'
    }
}

// Default device: gpu (model-native)
params.device = params.device ?: 'gpu'

// Load model-specific configs
includeConfig 'conf/modules.config'
