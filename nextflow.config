/*
========================================================================================
    RiboZoo Nextflow config
========================================================================================
*/

manifest {
    name            = 'RiboZoo'
    author          = 'Eric'
    homePage        = 'https://github.com/ericmalekos/RiboZoo'
    description     = 'Model zoo for riboseq / translation-efficiency prediction'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}

// Default pipeline parameters
params {
    // ----- RiboNN (sequence → TE prediction) -----
    ribonn_input                  = null
    ignore_ribonn                 = false

    // ----- Riboformer (ribo-seq density refinement) -----
    // riboformer_input expects a directory containing:
    //   - <reference>_f.wig, <reference>_r.wig (forward/reverse ribosome coverage)
    //   - <target>_f.wig,    <target>_r.wig
    //   - *.fasta (genome), *.gff3 (annotation)
    riboformer_input              = null
    riboformer_reference_wig      = null     // base name of reference WIG pair
    riboformer_target_wig         = null     // base name of target WIG pair
    riboformer_model              = 'yeast_disome'
    riboformer_psite              = 14
    riboformer_wsize              = 40
    riboformer_threshold          = 25
    ignore_riboformer             = false

    // ----- RiboTIE (ribo-seq-informed ORF detection) -----
    // ribotie_input expects a directory containing: genome FASTA, GTF annotation,
    // and transcriptome-mapped BAM files. ribotie_config is a YAML config file
    // pointing at those files with relative paths (see upstream TRISTAN README).
    // NOTE: RiboTIE fine-tunes on the user's ribo-seq data before prediction.
    // On CPU this is slow for real datasets (hours+) — use a GPU profile for
    // realistic inputs.
    ribotie_input                 = null
    ribotie_config                = null
    ribotie_max_epochs            = null
    ribotie_patience              = null
    ignore_ribotie                = false

    // ----- TranslationAI (TIS/TTS/ORF prediction from sequence) -----
    // LICENSE: Source code AGPL-3.0, model weights CC BY-NC 4.0 (non-commercial only).
    // Input: FASTA of mature mRNA sequences.
    translationai_input           = null
    translationai_tis_threshold   = 0.5
    translationai_tts_threshold   = 0.5
    ignore_translationai          = false

    // ----- CodonTransformer (codon optimization / design) -----
    // Input: FASTA of amino acid sequences.
    // Output: FASTA of optimized DNA coding sequences.
    codontransformer_input        = null
    codontransformer_organism     = 'Homo sapiens'  // any of 164 organisms
    ignore_codontransformer       = false

    // ----- Saluki (mRNA half-life prediction from sequence) -----
    // Input: FASTA with lowercase=UTR, uppercase=CDS convention
    // Output: preds.npy (log2 mRNA half-life)
    saluki_input                  = null
    saluki_species                = 'human' // 'human' or 'mouse'
    ignore_saluki                 = false

    // ----- seq2ribo (GPU-only: mRNA sequence → riboseq/TE/protein prediction) -----
    // LICENSE: CMU Academic/Non-Commercial Research Use Only. Commercial use prohibited.
    // Requires CUDA GPU — auto-skipped under `--profile cpu`.
    seq2ribo_input                = null     // FASTA file with mRNA sequences
    seq2ribo_task                 = 'te'     // riboseq, te, or protein
    seq2ribo_cell_line            = 'hek293' // hek293, lcl, rpe, or ipsc
    seq2ribo_use_utr              = false    // use UTR mode for TE prediction
    ignore_seq2ribo               = false

    // Output
    outdir                = 'results'
}

// Default container engine options
docker.enabled    = false
singularity.enabled = false

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    // Hardware profiles: default is model-native (usually GPU); `cpu` forces CPU images.
    cpu {
        params.device = 'cpu'
    }

    gpu {
        params.device = 'gpu'
        docker.runOptions = '--runtime=nvidia -e NVIDIA_VISIBLE_DEVICES=all -u $(id -u):$(id -g)'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// Default device: gpu (model-native)
params.device = params.device ?: 'gpu'

// Load model-specific configs
includeConfig 'conf/modules.config'
