/*
========================================================================================
    Test profile: minimal inputs for CI and local smoke tests
========================================================================================
*/

params {
    // RiboNN: sequence → TE prediction (small ~30-transcript test input)
    ribonn_input     = "${projectDir}/tests/data/ribonn_prediction_input.txt"

    // Riboformer: skipped in the default test profile because the minimum-realistic
    // yeast input set is ~240 MB (WIG + genome + GFF3) — too large to commit.
    // Use `-profile test_riboformer` (below) or the full `-profile test_all`
    // with riboformer_input pointing at a locally-downloaded dataset dir.
    ignore_riboformer = true

    // RiboTIE: skipped in the default test profile because the upstream test
    // data (tiny snippet FASTA+GTF+BAMs) is bundled inside the Docker image
    // and requires extracting it to a host directory to run through Nextflow.
    // A dedicated test config below does this extraction on demand.
    ignore_ribotie    = true

    // CodonTransformer: skipped in default test profile — model loading
    // is slow on CPU (~30s) and not critical for pipeline smoke test.
    ignore_codontransformer = true

    // TranslationAI: skipped in default test profile — the bundled example
    // data is inside the Docker image, not committed to the repo.
    ignore_translationai = true

    // Saluki: skipped in default test profile because the image requires
    // an 18.8 GB Zenodo download at build time — unlikely to be pre-built
    // on CI runners. Test manually.
    ignore_saluki     = true

    // seq2ribo: GPU-only, auto-skipped under CPU test profile anyway.
    ignore_seq2ribo   = true

    outdir           = 'results_test'
}
