/*
========================================================================================
    Test profile: minimal inputs for CI and local smoke tests.
    Only sets _input for models that complete in <60s on CPU.
    Models without _input set here are simply not run.
========================================================================================
*/

params {
    ribonn_input            = "${projectDir}/tests/data/ribonn_prediction_input.txt"
    rnafm_input             = "${projectDir}/tests/data/rnafm_test.fa"
    rinalmo_input           = "${projectDir}/tests/data/rnafm_test.fa"
    ernierna_input          = "${projectDir}/tests/data/rnafm_test.fa"
    codontransformer_input  = "${projectDir}/tests/data/codontransformer_test.fa"
    saluki_input            = "${projectDir}/tests/data/saluki_test.fa"
    translationai_input     = "${projectDir}/tests/data/translationai_test.fa"
    utrlm_input             = "${projectDir}/tests/data/utrlm_test.fa"
    multirm_input           = "${projectDir}/tests/data/multirm_test.fa"
    rnaformer_input         = "${projectDir}/tests/data/rnaformer_test.fa"
    spotrna_input           = "${projectDir}/tests/data/spotrna_test.fa"

    ribotie_input           = "${projectDir}/tests/data/ribotie"
    ribotie_config          = "${projectDir}/tests/data/ribotie_config.yml"
    ribotie_max_epochs      = 1
    ribotie_patience        = 1

    // Not tested under -profile test (too slow or special requirements):
    //   riboformer  — needs 240 MB dataset
    //   seq2ribo    — GPU-only           (covered by -profile test_gpu)
    //   rhofold     — ~5 min on CPU      (covered by -profile test_gpu)

    outdir                  = 'results_test'
}
