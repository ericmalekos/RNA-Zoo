/*
========================================================================================
    Test profile for the precomputed-embeddings short-circuit fine-tune path.
    Each model's <x>_finetune_input + <x>_finetune_embeddings are both set, so the
    workflow skips <x>_predict.py and feeds the .npy directly into the head trainer.

    Opt in via:
      nextflow run . -profile test_finetune_from_emb,docker,cpu     (CPU-runnable subset)
      nextflow run . -profile test_finetune_from_emb,docker,gpu     (full set incl. GPU-only)
    GPU-only fine-tunes (Orthrus, HydraRNA) auto-skip under -profile cpu.

    Embeddings fixture is a generic random (30, 256) .npy — finetune_head.py is
    dim-agnostic. val Pearson r will be near zero because the embeddings carry
    no information about the labels; the smoke verifies wiring + finite metrics.
========================================================================================
*/

params {
    rnafm_finetune_input          = "${projectDir}/tests/data/foundation_finetune.tsv"
    rnafm_finetune_label          = "label"
    rnafm_finetune_epochs         = 1
    rnafm_finetune_embeddings     = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    rinalmo_finetune_input        = "${projectDir}/tests/data/foundation_finetune.tsv"
    rinalmo_finetune_label        = "label"
    rinalmo_finetune_epochs       = 1
    rinalmo_finetune_embeddings   = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    ernierna_finetune_input       = "${projectDir}/tests/data/foundation_finetune.tsv"
    ernierna_finetune_label       = "label"
    ernierna_finetune_epochs      = 1
    ernierna_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    rnaernie_finetune_input       = "${projectDir}/tests/data/foundation_finetune.tsv"
    rnaernie_finetune_label       = "label"
    rnaernie_finetune_epochs      = 1
    rnaernie_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    plantrnafm_finetune_input     = "${projectDir}/tests/data/foundation_finetune.tsv"
    plantrnafm_finetune_label     = "label"
    plantrnafm_finetune_epochs    = 1
    plantrnafm_finetune_embeddings = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    calm_finetune_input           = "${projectDir}/tests/data/foundation_finetune.tsv"
    calm_finetune_label           = "label"
    calm_finetune_epochs          = 1
    calm_finetune_embeddings      = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    mrnabert_finetune_input       = "${projectDir}/tests/data/foundation_finetune.tsv"
    mrnabert_finetune_label       = "label"
    mrnabert_finetune_epochs      = 1
    mrnabert_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    // GPU-only fine-tunes (auto-skip under -profile cpu)
    orthrus_finetune_input        = "${projectDir}/tests/data/foundation_finetune.tsv"
    orthrus_finetune_label        = "label"
    orthrus_finetune_epochs       = 1
    orthrus_finetune_embeddings   = "${projectDir}/tests/data/foundation_finetune_emb.npy"

    hydrarna_finetune_input       = "${projectDir}/tests/data/foundation_finetune.tsv"
    hydrarna_finetune_label       = "label"
    hydrarna_finetune_epochs      = 1
    hydrarna_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"
}
