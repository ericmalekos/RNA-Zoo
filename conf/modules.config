/*
========================================================================================
    Per-module configuration: container images and publish directories.
    Each model publishes to params.<model>_outdir if set, else <outdir>/<model>.
========================================================================================
*/

process {
    withName: 'RIBONN' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-ribonn-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-ribonn:latest'
        publishDir = [
            path: { params.ribonn_outdir ?: "${params.outdir}/ribonn" },
            mode: 'copy'
        ]
    }

    withName: 'RIBONN_FINETUNE' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-ribonn-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-ribonn:latest'
        publishDir = [
            path: { params.ribonn_finetune_outdir ?: "${params.outdir}/ribonn_finetune" },
            mode: 'copy'
        ]
    }

    withName: 'RIBOFORMER' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-riboformer-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-riboformer:latest'
        publishDir = [
            path: { params.riboformer_outdir ?: "${params.outdir}/riboformer" },
            mode: 'copy'
        ]
    }

    withName: 'RIBOTIE' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-tristan-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-tristan:latest'
        publishDir = [
            path: { params.ribotie_outdir ?: "${params.outdir}/ribotie" },
            mode: 'copy'
        ]
    }

    withName: 'SEQ2RIBO' {
        container = 'ghcr.io/ericmalekos/rnazoo-seq2ribo:latest'
        publishDir = [
            path: { params.seq2ribo_outdir ?: "${params.outdir}/seq2ribo" },
            mode: 'copy'
        ]
    }

    withName: 'TRANSLATIONAI' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-translationai-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-translationai:latest'
        publishDir = [
            path: { params.translationai_outdir ?: "${params.outdir}/translationai" },
            mode: 'copy'
        ]
    }

    withName: 'SALUKI' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-saluki-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-saluki:latest'
        publishDir = [
            path: { params.saluki_outdir ?: "${params.outdir}/saluki" },
            mode: 'copy'
        ]
    }

    withName: 'CODONTRANSFORMER' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-codontransformer-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-codontransformer:latest'
        publishDir = [
            path: { params.codontransformer_outdir ?: "${params.outdir}/codontransformer" },
            mode: 'copy'
        ]
    }

    withName: 'RNAFM' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-rnafm-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-rnafm:latest'
        publishDir = [
            path: { params.rnafm_outdir ?: "${params.outdir}/rnafm" },
            mode: 'copy'
        ]
    }

    withName: 'RINALMO' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-rinalmo-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-rinalmo:latest'
        publishDir = [
            path: { params.rinalmo_outdir ?: "${params.outdir}/rinalmo" },
            mode: 'copy'
        ]
    }

    withName: 'ERNIERNA' {
        container = 'ghcr.io/ericmalekos/rnazoo-ernierna:latest'
        publishDir = [
            path: { params.ernierna_outdir ?: "${params.outdir}/ernierna" },
            mode: 'copy'
        ]
    }

    withName: 'RNAFORMER' {
        container = 'ghcr.io/ericmalekos/rnazoo-rnaformer:latest'
        publishDir = [
            path: { params.rnaformer_outdir ?: "${params.outdir}/rnaformer" },
            mode: 'copy'
        ]
    }

    withName: 'RHOFOLD' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-rhofold-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-rhofold:latest'
        publishDir = [
            path: { params.rhofold_outdir ?: "${params.outdir}/rhofold" },
            mode: 'copy'
        ]
    }

    withName: 'SPOTRNA' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-spotrna-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-spotrna:latest'
        publishDir = [
            path: { params.spotrna_outdir ?: "${params.outdir}/spotrna" },
            mode: 'copy'
        ]
    }

    withName: 'UTRLM_FINETUNE' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-utrlm-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-utrlm:latest'
        publishDir = [
            path: { params.utrlm_finetune_outdir ?: "${params.outdir}/utrlm_finetune" },
            mode: 'copy'
        ]
    }

    withName: 'MULTIRM' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-multirm-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-multirm:latest'
        publishDir = [
            path: { params.multirm_outdir ?: "${params.outdir}/multirm" },
            mode: 'copy'
        ]
    }

    withName: 'UTRLM' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-utrlm-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-utrlm:latest'
        publishDir = [
            path: { params.utrlm_outdir ?: "${params.outdir}/utrlm" },
            mode: 'copy'
        ]
    }
}
