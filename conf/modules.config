/*
========================================================================================
    Per-module configuration: container images and publish directories.
    Each model publishes to params.<model>_outdir if set, else <outdir>/<model>.
========================================================================================
*/

process {
    withName: 'RIBONN' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-ribonn-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-ribonn:latest'
        publishDir = [
            path: { params.ribonn_outdir ?: "${params.outdir}/ribonn" },
            mode: 'copy'
        ]
    }

    withName: 'RIBONN_FINETUNE' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-ribonn-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-ribonn:latest'
        publishDir = [
            path: { params.ribonn_finetune_outdir ?: "${params.outdir}/ribonn_finetune" },
            mode: 'copy'
        ]
    }

    withName: 'RIBOFORMER' {
