/*
========================================================================================
    Per-module configuration: container images and publish directories
========================================================================================
*/

process {
    withName: 'RIBONN' {
        container = params.device == 'cpu'
            ? 'ghcr.io/ericmalekos/rnazoo-ribonn-cpu:latest'
            : 'ghcr.io/ericmalekos/rnazoo-ribonn:latest'
        publishDir = [
            path: { "${params.outdir}/ribonn" },
            mode: 'copy'
        ]
    }

    withName: 'RIBOFORMER' {
        // Riboformer supports CPU and GPU from the same image.
        container = 'ghcr.io/ericmalekos/rnazoo-riboformer:latest'
        publishDir = [
            path: { "${params.outdir}/riboformer" },
            mode: 'copy'
        ]
    }

    withName: 'RIBOTIE' {
        // TRISTAN / RiboTIE — CPU image. GPU variant TODO.
        container = 'ghcr.io/ericmalekos/rnazoo-tristan:latest'
        publishDir = [
            path: { "${params.outdir}/ribotie" },
            mode: 'copy'
        ]
    }

    withName: 'CODONTRANSFORMER' {
        // CPU and GPU both work. BigBird model (~358 MB weights pre-cached).
        container = 'ghcr.io/ericmalekos/rnazoo-codontransformer:latest'
        publishDir = [
            path: { "${params.outdir}/codontransformer" },
            mode: 'copy'
        ]
    }

    withName: 'TRANSLATIONAI' {
        // TF 1.15 + Keras 2.x; CPU and GPU both work.
        container = 'ghcr.io/ericmalekos/rnazoo-translationai:latest'
        publishDir = [
            path: { "${params.outdir}/translationai" },
            mode: 'copy'
        ]
    }

    withName: 'SALUKI' {
        // TensorFlow-based; CPU and GPU both work (CPU is slower).
        container = 'ghcr.io/ericmalekos/rnazoo-saluki:latest'
        publishDir = [
            path: { "${params.outdir}/saluki" },
            mode: 'copy'
        ]
    }

    withName: 'SEQ2RIBO' {
        // GPU-only. Uses nvidia/cuda:11.8.0 base image.
        container = 'ghcr.io/ericmalekos/rnazoo-seq2ribo:latest'
        publishDir = [
            path: { "${params.outdir}/seq2ribo" },
            mode: 'copy'
        ]
    }
}
