/*
========================================================================================
    Test profile addendum for foundation-model linear-probe fine-tuning.
    Layered on top of conf/test.config; opt in via:
      nextflow run . -profile test_finetune,docker,cpu     (CPU-runnable subset)
      nextflow run . -profile test_finetune,docker,gpu     (full set incl. GPU-only)
    GPU-only fine-tunes (Orthrus, HydraRNA) auto-skip under -profile cpu.
    Each fine-tune runs 1 epoch on the 30-seq fixture — ~30-60 sec per model on GPU,
    a few minutes on CPU. The smoke verifies wiring + finite metrics, not learning quality.
========================================================================================
*/

params {
    rnafm_finetune_input         = "${projectDir}/tests/data/foundation_finetune.tsv"
    rnafm_finetune_label         = "label"
    rnafm_finetune_epochs        = 1

    rinalmo_finetune_input       = "${projectDir}/tests/data/foundation_finetune.tsv"
    rinalmo_finetune_label       = "label"
    rinalmo_finetune_epochs      = 1

    ernierna_finetune_input      = "${projectDir}/tests/data/foundation_finetune.tsv"
    ernierna_finetune_label      = "label"
    ernierna_finetune_epochs     = 1

    rnaernie_finetune_input      = "${projectDir}/tests/data/foundation_finetune.tsv"
    rnaernie_finetune_label      = "label"
    rnaernie_finetune_epochs     = 1

    plantrnafm_finetune_input    = "${projectDir}/tests/data/foundation_finetune.tsv"
    plantrnafm_finetune_label    = "label"
    plantrnafm_finetune_epochs   = 1

    calm_finetune_input          = "${projectDir}/tests/data/foundation_finetune.tsv"
    calm_finetune_label          = "label"
    calm_finetune_epochs         = 1

    mrnabert_finetune_input      = "${projectDir}/tests/data/foundation_finetune.tsv"
    mrnabert_finetune_label      = "label"
    mrnabert_finetune_epochs     = 1

    // GPU-only fine-tunes (auto-skip under -profile cpu)
    orthrus_finetune_input       = "${projectDir}/tests/data/foundation_finetune.tsv"
    orthrus_finetune_label       = "label"
    orthrus_finetune_epochs      = 1

    hydrarna_finetune_input      = "${projectDir}/tests/data/foundation_finetune.tsv"
    hydrarna_finetune_label      = "label"
    hydrarna_finetune_epochs     = 1
}
