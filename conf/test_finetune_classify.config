/*
========================================================================================
    Test profile for classification fine-tunes via the precomputed-embeddings
    short-circuit. Each model's <x>_finetune_input + <x>_finetune_embeddings are
    both set, with the input TSV carrying 2-class string labels ("high"/"low").
    The workflow skips <x>_predict.py and feeds the .npy directly into the head
    trainer, which auto-detects classification from the string labels.

    Opt in via:
      nextflow run . -profile test_finetune_classify,docker,cpu     (CPU-runnable subset)
      nextflow run . -profile test_finetune_classify,docker,gpu     (full set)

    Embeddings fixture is the same (30, 256) random .npy used by
    test_finetune_from_emb. val accuracy will be near random (~0.5) because
    the embeddings carry no signal; the smoke verifies wiring + finite metrics.

    All 9 models tested — Orthrus and HydraRNA also work here because the
    finetune-head image is CPU-only and decoupled from the model image.
========================================================================================
*/

params {
    rnafm_finetune_input          = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    rnafm_finetune_label          = "bin"
    rnafm_finetune_epochs         = 1
    rnafm_finetune_embeddings     = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    rnafm_finetune_task           = "classification"

    rinalmo_finetune_input        = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    rinalmo_finetune_label        = "bin"
    rinalmo_finetune_epochs       = 1
    rinalmo_finetune_embeddings   = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    rinalmo_finetune_task         = "classification"

    ernierna_finetune_input       = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    ernierna_finetune_label       = "bin"
    ernierna_finetune_epochs      = 1
    ernierna_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    ernierna_finetune_task        = "classification"

    rnaernie_finetune_input       = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    rnaernie_finetune_label       = "bin"
    rnaernie_finetune_epochs      = 1
    rnaernie_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    rnaernie_finetune_task        = "classification"

    plantrnafm_finetune_input     = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    plantrnafm_finetune_label     = "bin"
    plantrnafm_finetune_epochs    = 1
    plantrnafm_finetune_embeddings = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    plantrnafm_finetune_task      = "classification"

    calm_finetune_input           = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    calm_finetune_label           = "bin"
    calm_finetune_epochs          = 1
    calm_finetune_embeddings      = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    calm_finetune_task            = "classification"

    mrnabert_finetune_input       = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    mrnabert_finetune_label       = "bin"
    mrnabert_finetune_epochs      = 1
    mrnabert_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    mrnabert_finetune_task        = "classification"

    orthrus_finetune_input        = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    orthrus_finetune_label        = "bin"
    orthrus_finetune_epochs       = 1
    orthrus_finetune_embeddings   = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    orthrus_finetune_task         = "classification"

    hydrarna_finetune_input       = "${projectDir}/tests/data/foundation_finetune_classify.tsv"
    hydrarna_finetune_label       = "bin"
    hydrarna_finetune_epochs      = 1
    hydrarna_finetune_embeddings  = "${projectDir}/tests/data/foundation_finetune_emb.npy"
    hydrarna_finetune_task        = "classification"
}
