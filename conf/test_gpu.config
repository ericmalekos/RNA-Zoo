/*
========================================================================================
    GPU test profile addendum: layers on top of conf/test.config to also exercise
    the models that are GPU-only or impractically slow on CPU.
    Use with: nextflow run . -profile test_gpu,docker,gpu
========================================================================================
*/

params {
    seq2ribo_input          = "${projectDir}/tests/data/seq2ribo_test.fa"
    rhofold_input           = "${projectDir}/tests/data/rhofold_test.fa"
    orthrus_input           = "${projectDir}/tests/data/orthrus_test.fa"
    drfold2_input           = "${projectDir}/tests/data/drfold2_test.fa"
    hydrarna_input          = "${projectDir}/tests/data/rnafm_test.fa"
}
